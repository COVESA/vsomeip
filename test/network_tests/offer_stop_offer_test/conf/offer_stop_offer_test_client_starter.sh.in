SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if ! source $SCRIPT_DIRECTORY/../setup_test.sh; then
    exit 1
fi

FAIL=0

exec_slave "./offer_stop_offer_test_service_starter.sh" &
SERVICE_PID="$!"

# start client
export VSOMEIP_CONFIGURATION=offer_stop_offer_test_client.json
export VSOMEIP_APPLICATION_NAME="client-sample"
./offer_stop_offer_test_client || FAIL=$(($FAIL+1))
wait $SERVICE_PID || FAIL=$(($FAIL+1))
exit $FAIL
