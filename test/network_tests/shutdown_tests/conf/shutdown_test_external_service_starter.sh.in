SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if ! source $SCRIPT_DIRECTORY/../setup_test.sh; then
    exit 1
fi


FAIL=0

if [[ $# -gt 1 && ($1 != "TCP" && $1 != "UDP" && $1 != "UDS") || ($2 != "CLIENT" && $2 != "SERVICE") ]]
then
    echo "The only allowed parameter to this script is TCP, UDP or UDS and CLIENT or SERVICE"
    echo "Like $0 TCP CLIENT"
    exit 1
fi

# Start the client
if [[ $# -gt 0 && $1 == "TCP" ]]; then
    export VSOMEIP_CONFIGURATION=shutdown_test_client_tcp.json
else
    export VSOMEIP_CONFIGURATION=shutdown_test_client_udp.json
fi

export VSOMEIP_APPLICATION_NAME=shutdown_test_client
if [[ $2 == "CLIENT" ]]; then
    ./shutdown_test_client_send $1 &
    CLIENT_PID=$!
else
    ./shutdown_test_client_receive $1 &
    CLIENT_PID=$!
fi

SERVICE_PID=0
exec_slave "./shutdown_test_external_service_start.sh $1 $2"
SERVICE_PID=$!

wait $CLIENT_PID || ((FAIL+=1))
wait $SERVICE_PID || ((FAIL+=1))

# Check if client and server both exited successfully
exit $FAIL
