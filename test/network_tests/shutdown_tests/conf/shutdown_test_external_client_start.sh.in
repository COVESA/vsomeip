if [[ $# -gt 1 && ($1 != "TCP" && $1 != "UDP" && $1 != "UDS") || ($2 != "CLIENT" && $2 != "SERVICE") ]]
then
    echo "The only allowed parameter to this script is TCP, UDP or UDS and CLIENT or SERVICE"
    echo "Like $0 TCP CLIENT"
    exit 1
fi

# Start the service
if [[ $# -gt 0 && $1 == "TCP" ]]; then
    export VSOMEIP_CONFIGURATION=shutdown_test_external_client_tcp.json
else
    export VSOMEIP_CONFIGURATION=shutdown_test_external_client_udp.json
fi

export VSOMEIP_APPLICATION_NAME=shutdown_test_client
if [[ $2 == "CLIENT" ]]; then
    ./shutdown_test_client_send $1
else
    ./shutdown_test_client_receive $1
fi
