SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if ! source $SCRIPT_DIRECTORY/../setup_test.sh; then
    exit 1
fi

FAIL=0

export VSOMEIP_APPLICATION_NAME="client-routingmanagerd"
export VSOMEIP_CONFIGURATION=debounce_filter_test_client.json
routingmanagerd &
PID_VSOMEIPD=$!

export VSOMEIP_APPLICATION_NAME="client-sample"
./debounce_filter_test_client &
PID_MASTER=$!

exec_slave "./debounce_filter_test_slave_starter.sh"
PID_SLAVE=$!

wait $PID_MASTER || FAIL=$(($FAIL+1))
wait $PID_SLAVE || FAIL=$(($FAIL+1))

kill $PID_VSOMEIPD
wait $PID_VSOMEIPD || FAIL=$(($FAIL+1))

exit $FAIL
