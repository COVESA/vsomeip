set -e -o pipefail
cleanup() {
    echo "Cleaning up..."
    [[ -n "$PID_VSOMEIPD" ]] && kill -9 "$PID_VSOMEIPD" 2>/dev/null || true
    [[ -n "$PID_SOMEIP_SEQUENCE_CHECKER" ]] && kill -9 "$PID_SOMEIP_SEQUENCE_CHECKER" 2>/dev/null || true
    iptables -D OUTPUT -j NFQUEUE --queue-num 0 2>/dev/null || true
}

trap cleanup EXIT

export VSOMEIP_CONFIGURATION=registration_check_config.json
export VSOMEIP_APPLICATION_NAME=routingmanagerd
# Start daemon
../../../examples/routingmanagerd/routingmanagerd &
PID_VSOMEIPD=$!

export PYTHONUNBUFFERED=1
python3 -u ./someip_sequence_checker.py &>someip_sequence_checker_output.txt &
PID_SOMEIP_SEQUENCE_CHECKER=$!

# Wait for the sequence checker to start
sleep 1

export VSOMEIP_APPLICATION_NAME=service-sample
./registration_check_test
TEST_RESULT=$?

# Validate sequence checker completed successfully
if [ $TEST_RESULT -eq 0 ]; then
    if ! grep -q "Sequence complete!" someip_sequence_checker_output.txt 2>/dev/null; then
        echo "ERROR: Sequence checker did not complete the expected SOME/IP registration sequence"
        echo "=== Begin of Sequence Checker Output ==="
        cat someip_sequence_checker_output.txt 2>/dev/null
        echo "=== End of Sequence Checker Output ==="
        TEST_RESULT=1
    fi
else
    echo "C++ test failed, showing sequence checker output for debugging:"
    echo "=== Begin of Sequence Checker Output ==="
    cat someip_sequence_checker_output.txt 2>/dev/null
    echo "=== End of Sequence Checker Output ==="
fi

exit $TEST_RESULT
