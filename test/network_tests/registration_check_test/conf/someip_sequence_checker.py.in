"""
    This script intercepts outgoing TCP packets using NetfilterQueue and Scapy,
    and checks for a specific sequence of SOMEIP protocol messages during
    application registration.
"""

from netfilterqueue import NetfilterQueue
from scapy.all import IP, TCP
from time import sleep
import os
import sys

# Protocol constants from protocol.hpp
ASSIGN_CLIENT_ID = 0x00
ASSIGN_CLIENT_ACK_ID = 0x01
REGISTER_APPLICATION_ID = 0x02
CONFIG_ID = 0x31

VALID_COMMANDS = {
    ASSIGN_CLIENT_ID,
    ASSIGN_CLIENT_ACK_ID,
    REGISTER_APPLICATION_ID,
    CONFIG_ID
}

# State machine constants
STATE_INITIAL = 0
STATE_AFTER_REGISTER_APPLICATION_ACK = 4
STATE_COMPLETE = 9

# Substitute these with the test IP at runtime
SRC = '@TEST_IP_MASTER@'
DST = '@TEST_IP_MASTER@'

# State machine variables for sequence detection
sequence_state = 0
my_counter = 0

def add_iptables_rule():
    """Add iptables rule to redirect outgoing packets to NFQUEUE 0."""
    iptablesr = "iptables -A OUTPUT -j NFQUEUE --queue-num 0"
    print("Adding iptable rules:", flush=True)
    print(iptablesr, flush=True)
    os.system(iptablesr)
    return iptablesr

def get_tcp_handshake_type(tcp_pkt):
    if tcp_pkt.flags == 'S':
        return 'SYN'
    elif tcp_pkt.flags == 'SA':
        return 'SYN/ACK'
    elif tcp_pkt.flags == 'A':
        return 'ACK'
    return None

def parse_someip_payload(payload):
    # Check if payload contains a vsomeip command
    if len(payload) >= 1:
        command = payload[0]
        if command in VALID_COMMANDS:
            return {
                'command': command,
                'payload': payload
            }
    return None

def process_packet(packet):
    global my_counter, sequence_state
    # Parse the packet, check TCP handshake and SOMEIP message sequence, and update state machine.    
    ip_pkt = IP(packet.get_payload())

    # Only process packets from SRC to DST with TCP
    if ip_pkt.src == SRC and ip_pkt.dst == DST and TCP in ip_pkt:
        tcp_pkt = ip_pkt[TCP]
        handshake = get_tcp_handshake_type(tcp_pkt)
        payload_bytes = bytes(tcp_pkt.payload)
        someip = parse_someip_payload(payload_bytes)

        # Print every packet first
        print(f"\nPacket {my_counter}: State {sequence_state}, Flags: {tcp_pkt.flags}", flush=True)

        # State machine for expected registration sequence
        if sequence_state == STATE_INITIAL and handshake == 'SYN':
            print("SYN detected", flush=True)
            sequence_state += 1
        elif sequence_state == 1 and handshake == 'SYN/ACK':
            print("SYN/ACK detected", flush=True)
            sequence_state += 1
        elif sequence_state == 2 and handshake == 'ACK':
            print("ACK detected", flush=True)
            sequence_state += 1
        elif sequence_state == 3 and someip and someip['command'] == ASSIGN_CLIENT_ID:
            print("VSOMEIP_ASSIGN_CLIENT detected", flush=True)
            sequence_state += 1        
        elif sequence_state == 4 and handshake == 'ACK':
            print("ACK for VSOMEIP_ASSIGN_CLIENT detected", flush=True)
            sequence_state += 1
        elif sequence_state == 5 and someip and someip['command'] == ASSIGN_CLIENT_ACK_ID:
            print("VSOMEIP_ASSIGN_CLIENT_ACK detected", flush=True)
            sequence_state += 1
        elif sequence_state == 6 and handshake == 'ACK':
            print("ACK for VSOMEIP_ASSIGN_CLIENT_ACK detected", flush=True)
            sequence_state += 1
        elif sequence_state == 7 and someip and someip['command'] == REGISTER_APPLICATION_ID:
            print("VSOMEIP_REGISTER_APPLICATION detected", flush=True)
            sequence_state += 1
        elif sequence_state == 8 and someip and someip['command'] == CONFIG_ID:
            print("VSOMEIP_CONFIG detected", flush=True)
            sequence_state += 1
        elif handshake == 'ACK' and sequence_state >= STATE_AFTER_REGISTER_APPLICATION_ACK:
            # Allow additional ACKs after state 3 without resetting - just ignore them
            print(f"Additional ACK ignored at state {sequence_state}", flush=True)
        else:
            if sequence_state > STATE_INITIAL and payload_bytes:
                print(f"Sequence broken at state {sequence_state}, resetting.", flush=True)
                sequence_state = STATE_INITIAL

        my_counter += 1
        if sequence_state == STATE_COMPLETE:
            print("Sequence complete! Sleeping for 1 second.", flush=True)
            sleep(1)
            sequence_state = STATE_INITIAL
            my_counter = 0
        
        # Print SOMEIP payload if present
        if payload_bytes:
            print(f"  Payload ({len(payload_bytes)} bytes): {' '.join(format(byte, '02x') for byte in payload_bytes)}", flush=True)

    # Always accept the packet to avoid blocking traffic
    packet.accept()

def main():
    """Main entry: bind NFQUEUE and process packets."""
    iptablesr = add_iptables_rule()
    nfqueue = NetfilterQueue()
    nfqueue.bind(0, process_packet)

    try:
        print("Starting NFQueue", flush=True)
        nfqueue.run()
    except KeyboardInterrupt:
        print("Stopping NFQueue", flush=True)
    finally:
        nfqueue.unbind()
        print("Flushing iptables.", flush=True)
        # Remove the iptables rule on exit
        os.system(iptablesr.replace("-A", "-D"))
        sys.stdout.flush()
        sys.stderr.flush()

if __name__ == "__main__":
    main()
