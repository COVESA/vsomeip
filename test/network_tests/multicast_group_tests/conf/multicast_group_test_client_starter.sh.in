SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if ! source $SCRIPT_DIRECTORY/../setup_test.sh; then
    exit 1
fi

# Start client routing host
export VSOMEIP_CONFIGURATION=multicast_group_test_client.json
export VSOMEIP_APPLICATION_NAME="routingmanagerd-client"
routingmanagerd &

HOST_PID=$!

FAIL=0

# Start first client
export VSOMEIP_APPLICATION_NAME="multicast_group_test_first_client"
./multicast_group_test_first_client &
FIRST_CLIENT_PID=$!

# Start second client and check if it fails
export VSOMEIP_APPLICATION_NAME="multicast_group_test_second_client"
./multicast_group_test_second_client || FAIL=$(($FAIL+1))

# Wait for the first client to finish.
wait "$FIRST_CLIENT_PID" || ((FAIL=1))

# Send a termination signal to the routing manager.
kill "$HOST_PID"

# Wait for the routing manager to exit.
wait "$HOST_PID" || ((FAIL+=1))

# Return the result of the test.
exit "$FAIL"

