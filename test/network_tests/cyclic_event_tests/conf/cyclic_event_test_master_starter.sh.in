SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if ! source $SCRIPT_DIRECTORY/../setup_test.sh; then
    exit 1
fi

# Configuration to be used by daemon and service.
export VSOMEIP_CONFIGURATION=service

# Start the routing manager.
export VSOMEIP_APPLICATION_NAME="service-daemon"
routingmanagerd &
DAEMON_PID=$!

# Start the test service.
export VSOMEIP_APPLICATION_NAME="service-sample"
./cyclic_event_test_service &
SERVICE_PID=$!

exec_slave "./cyclic_event_test_slave_starter.sh"
SLAVE_PID=$!

# Whether the test failed.
FAIL=0

# Wait for the service and client to finish.
wait "$SERVICE_PID" || FAIL=$(($FAIL+1))
wait "$SLAVE_PID" || FAIL=$(($FAIL+1))

# Send a termination signal to the routing manager.
kill "$DAEMON_PID"

# Wait for the routing manager to exit.
wait "$DAEMON_PID" || FAIL=$(($FAIL+1))

# Return the result of the test.
exit "$FAIL"
