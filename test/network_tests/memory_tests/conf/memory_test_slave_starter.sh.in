FLAMEGRAPH_DIR=/opt/flamegraph/
VALGRIND_TYPE=@VALGRIND_TYPE@

export VSOMEIP_CONFIGURATION=memory_test_client.json
export VSOMEIP_APPLICATION_NAME="client-sample"
PERF_TOOL=$(find /usr/lib/linux-tools* -type f -name "perf" | head -n 1)

if [ ! -f "$PERF_TOOL" ]; then
    echo "WARNING: Failed to find installation of perf. Running test without profiling."
fi

# If VALGRIND_TYPE is empty and perf is available, run under perf; otherwise run normally
if [ -z "${VALGRIND_TYPE}" ] && [ -f "$PERF_TOOL" ]; then
    echo "[flamegraph] Starting memory_test_client under perf recording..."
    $PERF_TOOL record -F 99 -g -o memory_test_client.perf.data -- ./memory_test_client
else
    ./memory_test_client
fi

# Generate flamegraph from recorded perf data (only if VALGRIND_TYPE is empty)
if [ -z "${VALGRIND_TYPE}" ] && [ -f memory_test_client.perf.data ]; then
    echo "[flamegraph] Perf data found, generating flamegraph..."
    # Generate interactive SVG flamegraph (open directly in any browser)
    $PERF_TOOL script -i memory_test_client.perf.data \
        | $FLAMEGRAPH_DIR/stackcollapse-perf.pl \
        | $FLAMEGRAPH_DIR/flamegraph.pl > memory_test_client_flamegraph.svg
    if [ $? -eq 0 ]; then
        echo "[flamegraph] SVG flamegraph generated: memory_test_client_flamegraph.svg"
    else
        echo "[flamegraph] ERROR: SVG flamegraph generation failed!" >&2
    fi

    # Generate perf script text file for import into Firefox Profiler
    # (profiler.firefox.com -> "Load a profile from file")
    $PERF_TOOL script -i memory_test_client.perf.data > memory_test_client_firefox_profiler.perf
    if [ $? -eq 0 ]; then
        echo "[flamegraph] Firefox Profiler file generated: memory_test_client_firefox_profiler.perf"
    else
        echo "[flamegraph] ERROR: Firefox Profiler file generation failed!" >&2
    fi
elif [ -n "${VALGRIND_TYPE}" ]; then
    echo "[flamegraph] VALGRIND_TYPE is set to '${VALGRIND_TYPE}', skipping flamegraph generation."
fi
