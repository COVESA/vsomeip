    "logging": {
        "level": "trace",
        "console": "true"
    },
    "tracing": {
        "enable": "true"
    },
    "applications": [
        {
            "name": "header_factory_test_service",
            "id": "0x1277"
        },
        {
            "name": "header_factory_test_client",
