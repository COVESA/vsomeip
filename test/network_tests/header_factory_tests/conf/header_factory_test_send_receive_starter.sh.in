SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if ! source $SCRIPT_DIRECTORY/../setup_test.sh; then
    exit 1
fi

FAIL=0

export VSOMEIP_CONFIGURATION=header_factory_test.json
export VSOMEIP_APPLICATION_NAME=routingmanagerd
routingmanagerd &
VSOMEIPD_PID=$!

# Start the service
export VSOMEIP_APPLICATION_NAME=header_factory_test_service
./header_factory_test_service &
SERVICE_PID=$!

# Start the client
export VSOMEIP_APPLICATION_NAME=header_factory_test_client
./header_factory_test_client || FAIL=$((FAIL+1))

# Wait until service is finished
# Fail gets incremented if service exit
# with a non-zero exit code
wait $SERVICE_PID || FAIL=$((FAIL+1))

kill $VSOMEIPD_PID
wait $VSOMEIPD_PID || FAIL=$((FAIL+1))

# Check if client and server both exited successfully
exit $FAIL
