SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if ! source $SCRIPT_DIRECTORY/../setup_test.sh; then
    exit 1
fi

# Purpose: This script is needed to start the services with
# one command. This is necessary as ctest - which is used to run the
# tests - isn't able to start multiple binaries for one testcase. Therefore
# the testcase simply executes this script. This script then runs the services
# and checks that all exit successfully.

FAIL=0

export VSOMEIP_CONFIGURATION=offer_test_big_sd_msg_master.json
# start daemon
export VSOMEIP_APPLICATION_NAME="client-routingmanager"
routingmanagerd &
PID_VSOMEIPD=$!

export VSOMEIP_APPLICATION_NAME="client-sample"
./offer_test_big_sd_msg_client &
CLIENT_PID=$!

exec_slave "./offer_test_big_sd_msg_slave_starter.sh"
SERVICE_PID=$!

wait $CLIENT_PID || FAIL=$(($FAIL+1))
wait $SERVICE_PID || FAIL=$(($FAIL+1))

# kill the services
kill $PID_VSOMEIPD
wait $PID_VSOMEIPD || FAIL=$(($FAIL+1))

exit $FAIL
