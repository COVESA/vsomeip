SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if ! source $SCRIPT_DIRECTORY/../setup_test.sh; then
    exit 1
fi

FAIL=0

if [ $# -lt 1 ]
then
    echo "Please pass a test mode to this script."
    echo "For example: $0 IN_SEQUENCE"
    echo "Valid subscription types include:"
    echo "            [IN_SEQUENCE, MIXED, INCOMPLETE, DUPLICATE, OVERLAP, OVERLAP_FRONT_BACK]"
    exit 1
fi
TESTMODE=$1
export VSOMEIP_APPLICATION_NAME="routingmanagerd"
export VSOMEIP_CONFIGURATION=someip_tp_test_master.json
# start daemon
routingmanagerd &
PID_VSOMEIPD=$!
# Start the services
export VSOMEIP_APPLICATION_NAME="service-sample"
./someip_tp_test_service $1 &
PID_SERVICE=$!

exec_slave "./someip_tp_test_msg_sender @TEST_IP_MASTER@ @TEST_IP_SLAVE@ $TESTMODE" &
PID_CLIENT=$!

# Wait for the service and client to finish
wait $PID_CLIENT || FAIL=$(($FAIL+1))
wait $PID_SERVICE || FAIL=$(($FAIL+1))

# Kill the daemon after the service ends
kill $PID_VSOMEIPD
wait $PID_VSOMEIPD || FAIL=$(($FAIL+1))

# Check if everything went well
exit $FAIL
