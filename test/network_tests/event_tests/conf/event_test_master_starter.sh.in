SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if ! source $SCRIPT_DIRECTORY/../setup_test.sh; then
    exit 1
fi

FAIL=0

if [ $# -lt 2 ]
then
    echo "Please pass a operation and communication mode to this script."
    echo "For example: $0 PAYLOAD_FIXED UDP"
    echo "Valid operation modes include [PAYLOAD_FIXED, PAYLOAD_DYNAMIC]"
    echo "Valid communication modes include [UDP, TCP]"
    exit 1
fi
TESTMODE=$1
COMMUNICATIONMODE=$2

export VSOMEIP_CONFIGURATION=event_test_master.json
export VSOMEIP_APPLICATION_NAME="client-routingmanagerd"
routingmanagerd &
PID_VSOMEIPD=$!

export VSOMEIP_APPLICATION_NAME="client-sample"
./event_test_client $TESTMODE $COMMUNICATIONMODE &
PID_CLIENT=$!

exec_slave "./event_test_slave_starter.sh $COMMUNICATIONMODE"
PID_SERVICE=$!

wait $PID_CLIENT || FAIL=$(($FAIL+1))
wait $PID_SERVICE || FAIL=$(($FAIL+1))

kill $PID_VSOMEIPD
wait $PID_VSOMEIPD || FAIL=$(($FAIL+1))

# Check if everything went well
exit $FAIL
