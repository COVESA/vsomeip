{
    "unicast":"@TEST_IP_MASTER@",
    "logging":
    {
        "level":"trace",
        "console":"true"
    },
    "tracing" :
    {
        "enable" : "true"
    },
    "routing":
    {
        "host":
        {
            "name":"routingmanagerd",
            "unicast":"@TEST_IP_MASTER@",
            "port":"13000"
        }
    },
    "service-discovery":
    {
        "enable":"false",
        "multicast":"224.0.0.1",
        "port":"30490",
        "protocol":"udp",
        "initial_delay_min":"10",
        "initial_delay_max":"10",
        "repetitions_base_delay":"30",
        "repetitions_max":"3",
        "cyclic_offer_delay":"20000",
        "ttl":"3"
    }
}
