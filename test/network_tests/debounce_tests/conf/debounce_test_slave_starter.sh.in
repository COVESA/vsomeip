SCRIPT_DIRECTORY="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if ! source $SCRIPT_DIRECTORY/../setup_test.sh; then
    exit 1
fi

FAIL=0

export VSOMEIP_CONFIGURATION=debounce_test_service.json
export VSOMEIP_APPLICATION_NAME=service-routingmanagerd
../../../examples/routingmanagerd/routingmanagerd &
PID_VSOMEIPD=$!

export VSOMEIP_APPLICATION_NAME=service-sample
./debounce_test_service || FAIL=$(($FAIL+1))

# kill the services
kill $PID_VSOMEIPD
wait $PID_VSOMEIPD || FAIL=$(($FAIL+1))
# Check if everything went well
exit $FAIL
